<?xml version="1.0" encoding="UTF-8"?>
<extentreports>
    <configuration>
        <!-- Report theme: standard or dark -->
        <theme>standard</theme>

        <!-- Document title -->
        <documentTitle>Test Automation Report</documentTitle>

        <!-- Report name -->
        <reportName>Cucumber Test Execution Report</reportName>

        <!-- Timestamp format -->
        <timeStampFormat>MMM dd, yyyy HH:mm:ss</timeStampFormat>

        <!-- Report encoding -->
        <encoding>UTF-8</encoding>

        <!-- JavaScript to enable screenshots -->
        <js>
            <![CDATA[
                // Enable screenshot modal
                console.log('ExtentReports loaded');
            ]]>
        </js>

        <!-- CSS Styling -->
        <css>
            <![CDATA[
                .test-content img {
                    max-width: 100%;
                    height: auto;
                    border: 2px solid #ddd;
                    border-radius: 4px;
                    margin: 10px 0;
                    cursor: pointer;
                }

                .test-content img:hover {
                    border-color: #3498db;
                    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
                }

                .log-message {
                    font-family: 'Courier New', monospace;
                    background: #f4f4f4;
                    padding: 10px;
                    border-left: 3px solid #3498db;
                    margin: 5px 0;
                }
            ]]>
        </css>
    </configuration>
</extentreports>